rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return getUserData().role == 'teacher';
    }

    // ADMIN: Collection group rule for class_progress (enables admin dashboard).
    // Read-only and teacher-only — student/own-progress writes go through the
    // owner rule under /users/{userId}/class_progress.
    // SECURITY: previously `allow read, write: if isAuthenticated();` permitted
    // any authenticated user to corrupt any student's progress doc.
    match /{path=**}/class_progress/{docId} {
      allow read: if isAuthenticated() && isTeacher();
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        isOwner(userId) ||
        (isTeacher() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['challenges']))
      );

      // TODO(security): teacher writes here exist solely to support
      // reviewChallenge (writes student's study_states + class_progress when
      // accepting/rejecting a dispute). This is overly broad — any teacher
      // account can write any student's subcollections regardless of class
      // membership. Follow-up: move reviewChallenge to a Cloud Function
      // (Admin SDK bypasses rules) and tighten this to `isOwner(userId)`.
      match /{subcollection}/{docId} {
        allow read: if isAuthenticated() && (isOwner(userId) || isTeacher());
        allow write: if isAuthenticated() && (isOwner(userId) || isTeacher());
      }
    }

    // CLASSES
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isTeacher();
      allow update: if isAuthenticated() && (
        resource.data.ownerTeacherId == request.auth.uid ||
        // Self-enrollment (joinClass) updates studentCount AND studentIds together;
        // both must be allowed or the studentIds write is rejected and the student
        // becomes a "phantom" member (present in members/ but missing from studentIds).
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount', 'studentIds'])
      );
      allow delete: if isAuthenticated()
        && resource.data.ownerTeacherId == request.auth.uid;

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && isOwner(memberId);
        allow delete: if isAuthenticated() && (
          isOwner(memberId) ||
          get(/databases/$(database)/documents/classes/$(classId)).data.ownerTeacherId == request.auth.uid
        );
      }

      match /words/{wordId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated()
          && get(/databases/$(database)/documents/classes/$(classId)).data.ownerTeacherId == request.auth.uid;
      }
    }

    // LISTS
    match /lists/{listId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isTeacher();
      allow update, delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      match /words/{wordId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated()
          && get(/databases/$(database)/documents/lists/$(listId)).data.ownerId == request.auth.uid;
      }
    }

    // ATTEMPTS
    // ⚠️ The attempt-write lockdown (W3) is NOT applied here yet — it is STAGED in
    //    `docs/plans/W3_attempts_lockdown.rules.md` and must be applied as the FINAL deploy step,
    //    only after SERVER_CHALLENGE_WRITE + SERVER_REVIEW_MARKER are ON + validated. Keeping the
    //    live rules unchanged keeps this file safe to deploy at any time (Codex: don't carry the
    //    lockdown live while the client still falls back to direct attempt writes).
    match /attempts/{attemptId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.teacherId == request.auth.uid
      );
      allow create: if isAuthenticated()
        && request.resource.data.studentId == request.auth.uid;

      // Student-side updates are limited to the `answers` array (for
      // submitChallenge, which mutates a nested challengeStatus on a single
      // answer). Score, passed, credibility, retention, gradedBy and similar
      // fields cannot be touched from the client.
      // Teacher updates: only the teacher of record for this attempt.
      allow update: if isAuthenticated() && (
        (resource.data.studentId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answers'])) ||
        (resource.data.teacherId == request.auth.uid && isTeacher())
      );

      // Allow students to delete their own attempts (for progress reset)
      allow delete: if isAuthenticated()
        && resource.data.studentId == request.auth.uid;
    }

    // SYSTEM LOGS (for reconciliation events)
    match /system_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && isTeacher();
    }

    // ========================================
    // AP BOOST COLLECTIONS
    // ========================================

    // AP TESTS - Public tests readable by all, teachers can write
    match /ap_tests/{testId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isTeacher();
    }

    // AP QUESTIONS - Readable by all (answer keys are in ap_answer_keys, not here)
    match /ap_questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isTeacher();
    }

    // AP STIMULI - Readable by all authenticated users
    match /ap_stimuli/{stimulusId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isTeacher();
    }

    // AP ANSWER KEYS - Teachers + Admin SDK only (students must never read)
    match /ap_answer_keys/{questionId} {
      allow read, write: if isAuthenticated() && isTeacher();
    }

    // AP SESSION STATE - Server creates; students update safe fields only
    match /ap_session_state/{sessionId} {
      // Students read own sessions; teachers read for monitoring
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isTeacher()
      );
      // Only Cloud Function (Admin SDK) can create sessions
      allow create: if false;
      // Students can update ONLY safe fields on their own sessions
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['answers', 'flaggedQuestions', 'annotations', 'strikethroughs',
                    'currentSectionIndex', 'currentQuestionIndex', 'sectionTimeRemaining',
                    'lastAction', 'lastHeartbeat', 'sessionToken', 'status']);
    }

    // AP TEST RESULTS - Immutable for students; only server creates, only teacher updates (grading)
    match /ap_test_results/{resultId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isTeacher()
      );
      // Only Cloud Function (Admin SDK) can create results
      allow create: if false;
      // Only the test creator (teacher) can update (for grading)
      allow update: if isAuthenticated() && isTeacher()
        && resource.data.teacherId == request.auth.uid;
    }

    // AP CLASSES - Teachers manage, students read if enrolled
    match /ap_classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isTeacher();
    }

    // AP ASSIGNMENTS - Teachers create, students read their assignments
    match /ap_assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isTeacher();
    }

  }
}
